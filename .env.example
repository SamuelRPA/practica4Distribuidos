# ============================================================
# Plantilla de variables de entorno
# Copiar a .env y rellenar valores reales. NUNCA commitear .env.
# ============================================================

# ---------- MongoDB Atlas (Pipeline RRV) ----------
# Reemplazar con la connection string de tu cluster Atlas.
# Atlas ya provee replica set con failover automático.
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.dzwxwhk.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=electoral_rrv

# ---------- PostgreSQL Cluster (Pipeline Oficial) ----------
# Apuntar a HAProxy / pgpool si se usa, o directo al primary.
# Para el cluster docker-compose local, primary es localhost:5432.
POSTGRES_HOST=localhost
POSTGRES_PORT_WRITE=5432
POSTGRES_PORT_READ=5433
POSTGRES_USER=oep_admin
POSTGRES_PASSWORD=cambiar_en_local
POSTGRES_DB=electoral_oficial
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=cambiar_replica

# ---------- RabbitMQ ----------
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_INGESTA=q_ingesta
RABBITMQ_QUEUE_VALIDACION=q_validacion
RABBITMQ_QUEUE_ESCRITURA=q_escritura
RABBITMQ_QUEUE_DLQ=q_dlq

# ---------- Servicio OCR ----------
OCR_SERVICE_URL=http://localhost:5000
OCR_TIMEOUT_MS=30000

# ---------- Backend ----------
BACKEND_PORT=3001
BACKEND_BASE_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=debug

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- N8N ----------
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiar

# ---------- SMS Gateway (mock para desarrollo) ----------
SMS_NUMEROS_AUTORIZADOS=+59170000001,+59170000002,+59170000003
SMS_GATEWAY_MODE=mock

# ---------- Umbrales de validación ----------
RRV_CONFIANZA_APROBADA=0.80
RRV_CONFIANZA_BAJA=0.50
RRV_DUPLICADO_CRITICO_UMBRAL=3
